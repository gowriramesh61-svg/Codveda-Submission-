4. Home.js
import { useContext } from "react";
import { UserContext } from "../context/UserContext";

function Home(){

const { username } = useContext(UserContext);

return(

<div className="page">

<h1>Home Page</h1>

<h2>Welcome {username}</h2>

<p>

This is the homepage of our Single Page Application.

</p>

</div>

);

}

export default Home;

