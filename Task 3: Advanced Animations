2.style.css
*{
margin:0;
padding:0;
box-sizing:border-box;
font-family:Arial,sans-serif;
}

body{
background:#f5f5f5;
overflow-x:hidden;
}

.hero{

height:100vh;

display:flex;

flex-direction:column;

justify-content:center;

align-items:center;

background:linear-gradient(135deg,#4facfe,#00f2fe);

color:white;

text-align:center;

}

.title{

font-size:4rem;

margin-bottom:20px;

}

.subtitle{

font-size:1.4rem;

margin-bottom:30px;

}

.btn{

padding:14px 30px;

font-size:18px;

border:none;

border-radius:30px;

cursor:pointer;

background:white;

transition:.3s;

}

.features{

padding:80px;

display:flex;

gap:30px;

justify-content:center;

flex-wrap:wrap;

}

.card{

width:280px;

padding:30px;

background:white;

border-radius:12px;

box-shadow:0 5px 15px rgba(0,0,0,.15);

text-align:center;

transition:.3s;

}

.card:hover{

transform:translateY(-10px);

}

@media(max-width:768px){

.title{
font-size:2.5rem;
}

.features{

flex-direction:column;

align-items:center;

}

}

3.script.js
gsap.registerPlugin(ScrollTrigger);

// Hero Timeline

const hero = gsap.timeline();

hero

.from(".title",{

opacity:0,

y:-100,

duration:1

})

.from(".subtitle",{

opacity:0,

y:40,

duration:.8

})

.from(".btn",{

scale:0,

duration:.5,

ease:"back.out(1.7)"

});

// Hover Animation

document.querySelector(".btn")

.addEventListener("mouseenter",()=>{

gsap.to(".btn",{

scale:1.1,

duration:.3

});

});

document.querySelector(".btn")

.addEventListener("mouseleave",()=>{

gsap.to(".btn",{

scale:1,

duration:.3

});

});

// Scroll Animation

gsap.from(".card",{

scrollTrigger:{

trigger:".features",

start:"top 80%"

},

opacity:0,

y:80,

duration:1,

stagger:.3

});

Timeline Animation
const tl = gsap.timeline();

tl.from(".logo",{

opacity:0,

x:-100,

duration:1

})

.from(".menu",{

opacity:0,

y:-40,

duration:.5

})

.from(".hero-text",{

opacity:0,

y:100,

duration:1

});

Scroll-based Animation
gsap.from(".feature",{

scrollTrigger:{

trigger:".feature",

start:"top 85%"

},

opacity:0,

x:-100,

duration:1

});

Hover Based Animation
gsap.to(".card",{

scale:1.05,

duration:.3

});

Accessibility
if (
window.matchMedia("(prefers-reduced-motion: reduce)").matches
){

gsap.globalTimeline.pause();

}
